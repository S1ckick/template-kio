\newcommand\printauthorsinfo{
	\@ifundefined{need@authors@info}{}{
		\par
		\addvspace{0pt}  % Добавляем отступ сверху
		\widowpenalty=300  % Запрещаем висячие строки
		\clubpenalty=300
